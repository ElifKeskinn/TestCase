# Backend API base URL.
# - Local development with Vite proxy: leave empty or set to "" so /api proxies through vite.config.ts.
# - Direct (no proxy) local: VITE_API_BASE_URL=http://localhost:8000
# - Production (Railway): VITE_API_BASE_URL=https://your-backend.up.railway.app
VITE_API_BASE_URL=http://localhost:8000
